# Copy to config.env and edit. chmod 600 config.env
# DO NOT commit config.env.

# --- Red Hat credentials (reposync container only) ---
#RH_USER="xxxx"
#RH_PASSWORD="replace-me"
# Optional activation key flow:
RH_ORG_ID="xxxx"
RH_ACTIVATION_KEY="xxxx"

# --- Installer media ---
# Your fips/stig and nofips ISOs are Image Builder "liveimg" installers
# (liveimg.tar.gz + osbuild.ks), NOT full package DVDs.
SOURCE_ISO="./rhel-8.10-fips-stig.iso"
# Alternatives:
# SOURCE_ISO="./rhel-8-nofips-nostig.iso"
# SOURCE_ISO="./rhel-8.10-x86_64-boot.iso"   # traditional package installer

# liveimg = Image Builder ISO (your fips-stig / nofips ISOs)
# packages = traditional Anaconda package install (boot.iso + offline BaseOS/AppStream)
KS_INSTALL_MODE="liveimg"

# --- Offline repo output ---
REPO_DIR="./out/offline-repo"
SYNC_REPOS="rhel-8-for-x86_64-baseos-rpms rhel-8-for-x86_64-appstream-rpms codeready-builder-for-rhel-8-x86_64-rpms"

# --- Kickstart identity (CHANGE THESE) ---
KS_HOSTNAME="rhel8-airgap"
KS_TIMEZONE="UTC"
# openssl passwd -6 'YourPassword'
KS_ROOT_PASSWORD_HASH='$6$rounds=4096$REPLACE$WITH_YOUR_OWN_HASH'
KS_USER_NAME="admin"
KS_USER_PASSWORD_HASH='$6$rounds=4096$REPLACE$WITH_YOUR_OWN_HASH'
KS_USER_GECOS="Local Admin"

# Partitioning: interactive (Anaconda UI) per your choice
KS_CLEARPART_ALL="no"
# Only used if you later switch to automated partitioning:
KS_DISK="sda"

# Network
KS_NETWORK_MODE="dhcp"
# KS_IP="192.168.1.50"
# KS_NETMASK="255.255.255.0"
# KS_GATEWAY="192.168.1.1"
# KS_NAMESERVER="192.168.1.1"

# FIPS: yes for fips-stig media (also preserves fips=1 on kernel cmdline)
KS_ENABLE_FIPS="yes"

# Install Server with GUI from offline repos in %post (liveimg may be minimal)
KS_WANT_GUI="yes"

# Include packages/recommended.txt
INCLUDE_RECOMMENDED="yes"

USB_REPO_LABEL="RHEL8OFFLINE"
REPOSYNC_IMAGE="registry.access.redhat.com/ubi8/ubi:8.10"

# Preserve STIG-ish kernel args already present on the fips-stig ISO when patching
PRESERVE_STIG_BOOT_ARGS="yes"

# Target USB for step 4 (destructive)
USB_DEVICE="/dev/sdb"
